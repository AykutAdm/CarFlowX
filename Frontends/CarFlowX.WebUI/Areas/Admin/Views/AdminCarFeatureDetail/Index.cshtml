@model List<ResultCarFeatureByCarIdDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xl-12">
                <div class="card admin-table-card">
                    <div class="card-body">
                        <div class="admin-page-header">
                            <h4 class="card-title admin-page-title">Araca Ait Özellikler Listesi</h4>
                            <p class="card-subtitle admin-page-desc mb-0">
                                Araca ait özellik ekleyebilir, mevcut özellikleri kaldırabilir veya güncelleyebilirsiniz.
                            </p>
                        </div>
                        <form method="post">
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <div class="form-check">
                                    <input type="hidden" asp-for="@Model[i].CarFeatureId" />
                                    <input type="hidden" asp-for="@Model[i].FeatureName" />
                                    <input type="checkbox" asp-for="@Model[i].Available" class="form-check-input" />
                                    <label class="form-check-label" for="@Model[i].Available">@Model[i].FeatureName</label>
                                </div>
                            }
                            <br />
                            <button class="btn btn-success">Değişiklikleri Kaydet</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

