@model List<ResultPricingDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xl-12">
                <div class="card admin-table-card">
                    <div class="card-body">
                        <div class="admin-page-header">
                            <h4 class="card-title admin-page-title">Ödeme Türleri Alanı</h4>
                            <p class="card-subtitle admin-page-desc mb-0">
                                Araçların günlük, haftalık, aylık kiralama opsiyonlarını bu sayfa üzerinden yönetebilirsiniz.
                            </p>
                        </div>
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Periyot Adı</th>
                                        <th>Sil</th>
                                        <th>Güncelle</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        count++;
                                        <tr>
                                            <td>@count</td>
                                            <td>@item.Name</td>
                                            <td><a href="/Admin/AdminPricing/RemovePricing/@item.PricingId" class="btn btn-outline-danger">Sil</a></td>
                                            <td><a href="/Admin/AdminPricing/UpdatePricing/@item.PricingId" class="btn btn-outline-success">Güncelle</a></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="admin-add-section">
                    <a href="/Admin/AdminPricing/CreatePricing" class="btn-admin-add">
                        <i class="ri-add-line"></i>
                        Yeni Ödeme Türü Ekle
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

