@model List<ResultAuthorDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xl-12">
                <div class="card admin-table-card">
                    <div class="card-body">
                        <div class="admin-page-header">
                            <h4 class="card-title admin-page-title">Yazar Listesi</h4>
                            <p class="card-subtitle admin-page-desc mb-0">
                                Bloglara yazı yazan yazarları bu sayfadan yönetebilirsiniz. Yazar girişi yaparken bilgileri eksiksiz girmeye özen gösterin.
                            </p>
                        </div>
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Ad Soyad</th>
                                        <th>Sil</th>
                                        <th>Güncelle</th>
                                        <th>Yazarın Blogları</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        count++;
                                        <tr>
                                            <td>@count</td>
                                            <td><img src="@item.ImageUrl" width="50" height="50" class="rounded mr-2" style="margin-right:10px" /> @item.Name</td>
                                            <td><a href="/Admin/AdminAuthor/RemoveAuthor/@item.AuthorId" class="btn btn-outline-danger">Sil</a></td>
                                            <td><a href="/Admin/AdminAuthor/UpdateAuthor/@item.AuthorId" class="btn btn-outline-success">Güncelle</a></td>
                                            <td><a href="/Admin/AdminAuthor/#/@item.AuthorId" class="btn btn-outline-dark">Yazarın Blogları</a></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="admin-add-section">
                    <a href="/Admin/AdminAuthor/CreateAuthor" class="btn-admin-add">
                        <i class="ri-add-line"></i>
                        Yeni Yazar Ekle
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>