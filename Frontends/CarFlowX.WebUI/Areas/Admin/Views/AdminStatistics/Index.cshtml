@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="page-content">
    <div class="container-fluid">
        <div class="admin-page-header mb-4">
            <h4 class="admin-page-title">İstatistikler</h4>
            <p class="admin-page-desc mb-0">
                CarFlowX platformuna ait anlık istatistikleri ve özet bilgileri bu sayfadan takip edebilirsiniz.
            </p>
        </div>

        <!-- Satır 1 -->
        <div class="row mb-4">
            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">Toplam Araç Sayısı</h5>
                            <span class="stat-badge">Aktif Araçlar</span>
                        </div>
                        <h2 class="stat-value"># @ViewBag.v</h2>
                        <div class="stat-meta">@ViewBag.v1 % <i class="mdi mdi-arrow-up"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.v1%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">Lokasyon Sayısı</h5>
                            <span class="stat-badge">Mevcut Lokasyonlar</span>
                        </div>
                        <h2 class="stat-value"># @ViewBag.locationCount</h2>
                        <div class="stat-meta">@ViewBag.locationCountRandom% <i class="mdi mdi-arrow-down"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.locationCountRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-warning">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">Toplam Personel</h5>
                            <span class="stat-badge">Yazar-Personel</span>
                        </div>
                        <h2 class="stat-value"># @ViewBag.authorCount</h2>
                        <div class="stat-meta">@ViewBag.authorCountRandom% <i class="mdi mdi-arrow-up"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.authorCountRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-info">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">Toplam Blog Sayısı</h5>
                            <span class="stat-badge">Tüm Zamanlar</span>
                        </div>
                        <h2 class="stat-value"># @ViewBag.blogCount</h2>
                        <div class="stat-meta">@ViewBag.blogCountRandom% <i class="mdi mdi-arrow-down"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.blogCountRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Satır 2 -->
        <div class="row mb-4">
            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">Toplam Marka Sayısı</h5>
                            <span class="stat-badge">Aktif Markalar</span>
                        </div>
                        <h2 class="stat-value"># @ViewBag.brandCount</h2>
                        <div class="stat-meta">@ViewBag.brandCountRandom% <i class="mdi mdi-arrow-up"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.brandCountRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">Ort. Araç Fiyatı (Günlük)</h5>
                            <span class="stat-badge">Günlük Kiralama</span>
                        </div>
                        <h2 class="stat-value">@ViewBag.avgRentPriceForDaily ₺</h2>
                        <div class="stat-meta">@ViewBag.avgRentPriceForDailyRandom% <i class="mdi mdi-arrow-down"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.avgRentPriceForDailyRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-warning">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">Ort. Araç Fiyatı (Haftalık)</h5>
                            <span class="stat-badge">Haftalık Kiralama</span>
                        </div>
                        <h2 class="stat-value">@ViewBag.avgRentPriceForWeekly ₺</h2>
                        <div class="stat-meta">@ViewBag.avgRentPriceForWeeklyRandom% <i class="mdi mdi-arrow-up"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.avgRentPriceForWeeklyRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-info">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">Ort. Araç Fiyatı (Aylık)</h5>
                            <span class="stat-badge">Aylık Kiralama</span>
                        </div>
                        <h2 class="stat-value">@ViewBag.avgRentPriceForMonthly ₺</h2>
                        <div class="stat-meta">@ViewBag.avgRentPriceForMonthlyRandom% <i class="mdi mdi-arrow-down"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.avgRentPriceForMonthlyRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Satır 3 -->
        <div class="row mb-4">
            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">Otomatik Vitesli Araç</h5>
                            <span class="stat-badge">Araç Sayısı</span>
                        </div>
                        <h2 class="stat-value"># @ViewBag.carCountByTranmissionIsAuto</h2>
                        <div class="stat-meta">@ViewBag.carCountByTranmissionIsAutoRandom% <i class="mdi mdi-arrow-up"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.carCountByTranmissionIsAutoRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">En Fazla Araçlı Marka</h5>
                            <span class="stat-badge">Marka Adı</span>
                        </div>
                        <h2 class="stat-value">@ViewBag.brandNameByMaxCar</h2>
                        <div class="stat-meta">@ViewBag.brandNameByMaxCarRandom% <i class="mdi mdi-arrow-down"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.brandNameByMaxCarRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-warning">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">En İyi Blog</h5>
                            <span class="stat-badge">En Fazla Yorum</span>
                        </div>
                        <h3 class="stat-value" style="font-size: 20px !important;">@ViewBag.blogTitleByMaxBlogComment</h3>
                        <div class="stat-meta">@ViewBag.blogTitleByMaxBlogCommentRandom% <i class="mdi mdi-arrow-up"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.blogTitleByMaxBlogCommentRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-info">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">10.000 Km Altı Araç</h5>
                            <span class="stat-badge">Araç Sayısı</span>
                        </div>
                        <h2 class="stat-value"># @ViewBag.carCountByKmSmallerThen1000</h2>
                        <div class="stat-meta">@ViewBag.carCountByKmSmallerThen1000Random% <i class="mdi mdi-arrow-down"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.carCountByKmSmallerThen1000Random%;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Satır 4 -->
        <div class="row">
            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">Benzin / Dizel Araç</h5>
                            <span class="stat-badge">Yakıt Türü</span>
                        </div>
                        <h2 class="stat-value"># @ViewBag.carCountByFuelGasolineOrDiesel</h2>
                        <div class="stat-meta">@ViewBag.carCountByFuelGasolineOrDieselRandom% <i class="mdi mdi-arrow-up"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.carCountByFuelGasolineOrDieselRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">Elektrikli Araç</h5>
                            <span class="stat-badge">Yakıt Türü</span>
                        </div>
                        <h2 class="stat-value"># @ViewBag.carCountByFuelElectric</h2>
                        <div class="stat-meta">@ViewBag.carCountByFuelElectricRandom% <i class="mdi mdi-arrow-down"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.carCountByFuelElectricRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-warning">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">En Pahalı Araç</h5>
                            <span class="stat-badge">Günlük Fiyat</span>
                        </div>
                        <h4 class="stat-value" style="font-size: 18px !important;">@ViewBag.carBrandAndModelByRentPriceDailyMax</h4>
                        <div class="stat-meta">@ViewBag.carBrandAndModelByRentPriceDailyMaxRandom% <i class="mdi mdi-arrow-up"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.carBrandAndModelByRentPriceDailyMaxRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 mb-4 mb-xl-0">
                <div class="card stat-card stat-info">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="stat-title mb-0">En Ucuz Araç</h5>
                            <span class="stat-badge">Günlük Fiyat</span>
                        </div>
                        <h3 class="stat-value" style="font-size: 20px !important;">@ViewBag.carBrandAndModelByRentPriceDailyMin</h3>
                        <div class="stat-meta">@ViewBag.carBrandAndModelByRentPriceDailyMinRandom% <i class="mdi mdi-arrow-down"></i></div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" role="progressbar" style="width: @ViewBag.carBrandAndModelByRentPriceDailyMinRandom%;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
